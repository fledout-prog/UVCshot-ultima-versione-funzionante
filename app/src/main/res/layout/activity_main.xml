<?xml version="1.0" encoding="utf-8"?>
<!--
    Landscape camera-style layout:
    - SurfaceView locked to 16:9 aspect ratio, filling available width.
    - Thin control bar at the bottom with a status label and capture button.
    - Black background matches camera-app conventions.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!--
        Preview surface.
        Width fills the parent; height is derived from the 16:9 ratio so the
        image is never stretched.  Centred vertically above the control bar.
    -->
    <SurfaceView
        android:id="@+id/previewSurface"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/controlBar"
        app:layout_constraintDimensionRatio="H,16:9"
        app:layout_constraintVertical_bias="0.5" />

    <!-- Control bar: status label (left) + capture button (right) -->
    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="#CC000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Initializing…"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1" />

        <Button
            android:id="@+id/captureButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Capture"
            android:minWidth="110dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>